---
import PageLayout from "./PageLayout.astro";
import TagList from "../components/TagList.astro";
import { formatDate } from "../utils/formatDate";
import { readingTime } from "../utils/readingTime";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  tags: string[];
  ogImage?: string;
  body: string;
}

const { title, description, publishedAt, tags, ogImage, body } = Astro.props;
---

<PageLayout title={title} description={description} ogImage={ogImage} type="article" publishedAt={publishedAt}>
  <article class="mx-auto max-w-3xl">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-4">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary mb-4">
        <time datetime={publishedAt.toISOString()}>
          {formatDate(publishedAt)}
        </time>
        <span class="text-border">&bull;</span>
        <span>{readingTime(body)}</span>
      </div>
      {tags.length > 0 && <TagList tags={tags} />}
    </header>
    <div class="prose prose-stone max-w-none">
      <slot />
    </div>
  </article>
</PageLayout>
