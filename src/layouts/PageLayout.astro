---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  type?: "website" | "article";
  publishedAt?: Date;
}

const { title, description, ogImage, noindex, type, publishedAt } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} noindex={noindex} type={type} publishedAt={publishedAt}>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1 mx-auto w-full max-w-5xl px-6 py-12">
      <slot />
    </main>
    <Footer />
  </div>
</BaseLayout>
