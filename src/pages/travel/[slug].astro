---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import { formatDate } from "../../utils/formatDate";

export async function getStaticPaths() {
  const entries = await getCollection("travel");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PageLayout title={entry.data.title} description={entry.data.excerpt}>
  <article class="mx-auto max-w-3xl">
    {entry.data.coverImage && (
      <img
        src={entry.data.coverImage}
        alt={entry.data.title}
        class="w-full h-64 sm:h-80 object-cover rounded-xl mb-8"
      />
    )}

    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-text mb-3">
        {entry.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
        <span>{entry.data.location}, {entry.data.country}</span>
        <span class="text-border">&bull;</span>
        <time datetime={entry.data.visitedAt.toISOString()}>
          {formatDate(entry.data.visitedAt)}
        </time>
      </div>
    </header>

    <div class="prose prose-stone max-w-none">
      <Content />
    </div>

    {entry.data.gallery.length > 0 && (
      <div class="mt-12">
        <h2 class="text-xl font-bold mb-6">Photos</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {entry.data.gallery.map((photo: string, i: number) => (
            <button
              type="button"
              class="cursor-zoom-in overflow-hidden rounded-lg"
              data-lightbox-src={photo}
              aria-label={`View ${entry.data.title} photo ${i + 1} full size`}
            >
              <img
                src={photo}
                alt={`${entry.data.title} photo ${i + 1}`}
                class="w-full h-48 object-cover transition-transform hover:scale-105"
              />
            </button>
          ))}
        </div>

        <!-- Lightbox -->
        <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm">
          <button
            id="lightbox-close"
            type="button"
            class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors cursor-pointer"
            aria-label="Close"
          >
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] rounded-lg object-contain" />
        </div>
      </div>
    )}

    <div class="mt-10 pt-6 border-t border-border">
      <a href="/travel" class="text-sm font-medium text-accent hover:text-accent-dark transition-colors">
        &larr; Back to travel
      </a>
    </div>
  </article>
</PageLayout>

<script>
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;

  document.querySelectorAll<HTMLButtonElement>("[data-lightbox-src]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = btn.dataset.lightboxSrc!;
      lightboxImg.src = src;
      lightboxImg.alt = btn.getAttribute("aria-label") ?? "";
      lightbox?.classList.remove("hidden");
      lightbox?.classList.add("flex");
    });
  });

  function closeLightbox() {
    lightbox?.classList.add("hidden");
    lightbox?.classList.remove("flex");
    lightboxImg.src = "";
  }

  document.getElementById("lightbox-close")?.addEventListener("click", closeLightbox);
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>
