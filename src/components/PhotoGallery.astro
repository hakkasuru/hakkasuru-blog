---
interface TravelEntry {
  title: string;
  location: string;
  country: string;
  coverImage?: string;
  slug: string;
  excerpt: string;
}

interface Props {
  entries: TravelEntry[];
}

const { entries } = Astro.props;
---

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {entries.map((entry) => (
    <a href={`/travel/${entry.slug}`} class="group block">
      <div class="rounded-xl border border-border bg-surface overflow-hidden transition-all hover:border-accent/40 hover:shadow-md">
        {entry.coverImage ? (
          <img
            src={entry.coverImage}
            alt={entry.title}
            class="w-full h-48 object-cover"
          />
        ) : (
          <div class="w-full h-48 bg-stone-100 flex items-center justify-center">
            <svg class="w-12 h-12 text-stone-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
        )}
        <div class="p-5">
          <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors mb-1">
            {entry.title}
          </h3>
          <p class="text-xs text-text-secondary mb-2">{entry.location}, {entry.country}</p>
          <p class="text-sm text-text-secondary line-clamp-2">{entry.excerpt}</p>
        </div>
      </div>
    </a>
  ))}
</div>
