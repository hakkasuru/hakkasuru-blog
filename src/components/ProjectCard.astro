---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  description: string;
  tags: string[];
  url?: string;
  repo?: string;
  status?: "active" | "archived" | "wip";
}

const { title, description, tags, url, repo, status = "active" } = Astro.props;

const statusColors = {
  active: "bg-green-100 text-green-800",
  wip: "bg-yellow-100 text-yellow-800",
  archived: "bg-stone-100 text-stone-600",
};
---

<div class="group rounded-xl border border-border bg-surface p-6 transition-all hover:border-accent/40 hover:shadow-md">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
      {url ? (
        <a href={url} target="_blank" rel="noopener noreferrer">{title}</a>
      ) : (
        title
      )}
    </h3>
    <span class:list={["shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium", statusColors[status]]}>
      {status}
    </span>
  </div>

  <p class="text-sm text-text-secondary mb-4 line-clamp-2">{description}</p>

  <div class="flex items-end justify-between gap-4">
    <TagList tags={tags} />
    <div class="flex items-center gap-3 shrink-0">
      {repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-secondary hover:text-accent transition-colors"
          aria-label={`${title} repository`}
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </a>
      )}
      {url && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-secondary hover:text-accent transition-colors"
          aria-label={`Visit ${title}`}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </div>
  </div>
</div>
